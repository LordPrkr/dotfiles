stateDiagram-v2
  [*] --> build_context

  state "Resolve the Code Brain project using CODE_BRAIN_ROOT or its fallback. Before numbering, run the project-spine bootstrap gate when needed. Capture independent source-repository base revisions and inspect every affected repository for unrelated staged or unstaged work; obtain Parker's explicit approval before using a dirty repository. Launch bounded read-only context work, and let only the parent persist notes, AGENTS.md, plan metadata, and KANBAN.md." as build_context
  build_context --> capture_domain: domain-modeling-needed
  build_context --> challenge_direction: context-ready-no-domain-changes

  state "Use domain-modeling for resolved terms and qualifying ADRs. Follow shared evidence rules and reciprocal ADR supersession. Return persistence and navigation updates to the parent." as capture_domain
  capture_domain --> challenge_direction: domain-captured

  state "Challenge assumptions, architecture, scope, or trajectory with a read-only oracle when useful; explicitly resolve its advice before drafting." as challenge_direction
  challenge_direction --> draft_plan: context-ready

  state "Move the card to In Progress. Read references/TEMPLATE.md and write a standalone status-draft plan with exact files, TDD-first steps, end-state snippets, verification, risks, questions, and artifact links. Never write legacy approved metadata." as draft_plan
  draft_plan --> review_plan: draft-ready

  state "Move the card to Review. Adversarially review the plan and evidence. Incorporate accepted findings without revision-history residue; substantive changes remain draft and return the card to In Progress." as review_plan
  review_plan --> draft_plan: changes-needed
  review_plan --> approval_gate: plan-ready

  state "Keep status draft and the card in Review while Parker decides. Only explicit approval changes status to approved and moves the card to Ready. A substantive revision returns to draft, In Progress, and review." as approval_gate
  approval_gate --> approved_ready: user-approved
  approval_gate --> draft_plan: revision-requested
  approval_gate --> done: abandon
  approval_gate --> done: supersede

  state "Stop with the approved card in Ready. Approval does not start implementation. Wait for an explicit implementation start or lifecycle decision." as approved_ready
  approved_ready --> implement: start-implementation
  approved_ready --> draft_plan: revise-plan
  approved_ready --> done: abandon
  approved_ready --> done: supersede

  state "Recheck every affected repository for unrelated staged or unstaged work and stop for Parker's approval if the boundary changed. Move the approved card to In Progress. Launch one fresh worker against the approved plan and base revisions. Require changed files, exit codes, validation evidence, deviations, risks, and blockers. Do not let subagents change navigation or workflow state." as implement
  implement --> review_implementation: implementation-ready
  implement --> persist_receipt: blocked
  implement --> persist_receipt: partial
  implement --> persist_receipt: reverted

  state "Move the card to Review. Run read-only correctness, validation, and simplicity review; inspect each repository diff and focused verification. Accepted fixes return the card to In Progress." as review_implementation
  review_implementation --> apply_fixes: fixes-needed
  review_implementation --> commit_decision: accepted
  review_implementation --> persist_receipt: blocked
  review_implementation --> persist_receipt: partial
  review_implementation --> persist_receipt: reverted

  state "Move the card to In Progress. Apply only approved fixes, rerun focused checks, then return to Review." as apply_fixes
  apply_fixes --> review_implementation: implementation-ready
  apply_fixes --> persist_receipt: blocked
  apply_fixes --> persist_receipt: partial
  apply_fixes --> persist_receipt: reverted

  state "Keep the accepted card in Review. Name every changed source repository and ask Parker which, if any, may be committed. Commit only authorized repositories before receipt persistence; leave all others uncommitted with deterministic hashes." as commit_decision
  commit_decision --> persist_receipt: commit-decision-recorded

  state "Read references/RECEIPT.md. Create receipt.md once and append the attempt with observable delivery, files, commands and exit codes, review, deviations, risks, follow-ups, and one evidence row per changed Git repository. Never claim the vault was committed." as persist_receipt
  persist_receipt --> done: receipt-accepted
  persist_receipt --> await_recovery: blocked-receipt
  persist_receipt --> await_recovery: partial-receipt
  persist_receipt --> await_recovery: reverted-receipt

  state "Leave plan status approved and the card Blocked. Offer only retry unchanged approved design, revise through draft and approval, abandon, supersede, or pause." as await_recovery
  await_recovery --> implement: retry-approved-plan
  await_recovery --> draft_plan: revise-plan
  await_recovery --> done: abandon
  await_recovery --> done: supersede
  await_recovery --> [*]: pause

  state "For an accepted receipt, set status implemented and move the card to Done. For abandonment or supersession, set the matching plan status and retain the card in Done with its suffix." as done
  done --> [*]
